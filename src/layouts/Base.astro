---
import "@fontsource/jetbrains-mono";
import "../styles/global.css";
import Lines from "@components/Lines.astro";
import Footer from "@components/Footer.astro";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  accent: string;
}

const { title, accent } = Astro.props;
---

<html lang="en" class="dark dark:bg-base dark:text-text overflow-y-scroll">
  <head>
    <Font cssVariable="--font-pixel" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="title" content={`Schleemilch | ${title}`} />
    <meta name="description" content="Schleemilch | Tech | Portfolio | Blog" />
    <title>Schleemilch | {title}</title>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <ClientRouter />
  </head>
  <body>
    <div class="isolate">
      <div class="max-w-screen overflow-x-hidden">
        <div
          class:list={[
            "[--gutter-width:2.5rem]",
            "grid",
            "grid-cols-1",
            "grid-rows-[1fr]",
            "justify-center",
            "lg:mx-0",
            "md:-mx-4",
            "md:grid-cols-[var(--gutter-width)_minmax(0,var(--breakpoint-2xl))_var(--gutter-width)]",
            "min-h-dvh",
          ]}
        >
          <!-- Left gutter (diagonal pattern) -->
          <div
            class:list={[
              "bg-[image:repeating-linear-gradient(315deg,_var(--pattern-fg)_0,_var(--pattern-fg)_1px,_transparent_0,_transparent_50%)]",
              "bg-[size:10px_10px]",
              "bg-fixed",
              "border-x",
              "border-x-(--pattern-fg)",
              "col-start-1",
              "dark:[--pattern-fg:var(--color-white)]/10",
              "hidden",
              "md:block",
              "row-span-full",
              "row-start-1",
            ]}
          >
          </div>
          <!-- Main content -->
          <div class="grid gap-24 pt-24 pb-32 sm:gap-40 sm:pb-40">
            <slot />
          </div>
          <div
            class:list={[
              "bg-[image:repeating-linear-gradient(315deg,_var(--pattern-fg)_0,_var(--pattern-fg)_1px,_transparent_0,_transparent_50%)]",
              "bg-[size:10px_10px]",
              "bg-fixed",
              "border-x",
              "border-x-(--pattern-fg)",
              "col-start-1",
              "dark:[--pattern-fg:var(--color-white)]/10",
              "hidden",
              "md:block",
              "md:col-start-3",
              "row-span-full",
              "row-start-1",
            ]}
          >
          </div>
        </div>
      </div>
      <div
        class="fixed inset-x-0 bottom-0 z-10 grid grid-cols-1 justify-center border-t dark:border-white/10 md:grid-cols-[var(--gutter-width)_minmax(0,var(--breakpoint-2xl))_var(--gutter-width)] md:-mx-4 lg:mx-0 [--gutter-width:2.5rem]"
      >
        <div class="hidden md:block"></div>
        <Lines before={false}>
          <Footer accent={accent} title={title} />
        </Lines>
        <div class="hidden md:block"></div>
      </div>
    </div>
  </body>
</html>
