---
import { Icon } from "astro-icon/components";

interface Props {
  accent: string;
  title: string;
}

const { accent, title } = Astro.props;

const socials = [
  { name: "Email", url: "mailto:contact.sschleemilch@posteo.net", icon: "email" },
  { name: "GitHub", url: "https://github.com/sschleemilch", icon: "github" },
  { name: "LinkedIn", url: "https://de.linkedin.com/in/sschleemilch", icon: "linkedin" },
];
---

<div class="flex items-stretch font-pixel text-sm select-none dark:bg-surface">
  <a
    href="/"
    aria-label="Home"
    class:list={[`dark:bg-${accent}`, "dark:text-base", "text-xl px-3 py-1 font-black uppercase hover:brightness-110"]}
  >
    S
  </a>
  <span class="hidden items-center px-3 py-2 dark:text-subtle tracking-wide sm:flex">
    ~/{title}
  </span>
  <span class="hidden sm:block flex-1 dark:bg-surface"></span>
  <span class="flex items-center gap-3 px-3 py-2 dark:text-muted text-xl max-sm:flex-1">
    {
      socials.map((item) => (
        <a href={item.url} aria-label={item.name} class="dark:hover:text-text dark:text-muted">
          <Icon name={`mdi:${item.icon}`} />
        </a>
      ))
    }
  </span>
  <a
    href="/impressum"
    class="flex items-center font-black px-3 py-2 dark:bg-hlm dark:text-subtle uppercase hover:dark:text-text"
  >
    LEGAL NOTICE
  </a>
</div>
